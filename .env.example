# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# GitHub (opcional mas recomendado — aumenta rate limit de 60 para 5000 req/hora)
# Crie em: github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Reddit (crie um app em: reddit.com/prefs/apps)
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=ContentAgents/1.0

# Twitter/X (username e senha da conta)
TWITTER_USERNAME=...
TWITTER_PASSWORD=...
